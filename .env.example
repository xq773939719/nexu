# ── API ──────────────────────────────────────────────

# Database (PostgreSQL via docker-compose)
DATABASE_URL=postgresql://nexu:nexu@localhost:5433/nexu_dev

# Auth
BETTER_AUTH_SECRET=change-me-to-a-random-string
BETTER_AUTH_URL=http://localhost:3000

# OAuth (optional for dev, required for production)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Encryption (AES-256-GCM, 32 bytes hex)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Slack OAuth (shared app)
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=

# Internal Auth (shared secret between API and Sidecar)
INTERNAL_API_TOKEN=change-me-internal-token

# OpenClaw config gateway auth token
GATEWAY_TOKEN=gw-secret-token

# LiteLLM Model Provider (optional — enables AI responses)
LITELLM_BASE_URL=
LITELLM_API_KEY=

# Server
PORT=3000
WEB_URL=http://localhost:5173

# ── Runtime Sidecar (Gateway) ───────────────────────

RUNTIME_POOL_ID=pool_local_01
RUNTIME_API_BASE_URL=http://localhost:3000
RUNTIME_POD_IP=127.0.0.1
