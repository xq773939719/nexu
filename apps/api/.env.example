# ── Database ─────────────────────────────────────────
# Use localhost:5433 for local dev, postgres:5432 inside Docker Compose
DATABASE_URL=postgresql://nexu:nexu@localhost:5433/nexu_dev

# ── Auth ─────────────────────────────────────────────
BETTER_AUTH_SECRET=nexu-dev-secret-change-in-production
BETTER_AUTH_URL=http://localhost:3000

# OAuth (leave empty for dev — will skip OAuth buttons)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Encryption (AES-256-GCM, 32 bytes hex) ──────────
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# ── Slack OAuth (create app at https://api.slack.com/apps) ──
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=

# ── WhatsApp (optional — leave empty to disable) ────
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# ── Gateway / Internal Auth ──────────────────────────
# Sidecar 调 API 内部接口的认证 token，需与 Sidecar 端一致，任意字符串
INTERNAL_API_TOKEN=gw-secret-token

# 写入 OpenClaw 配置的 gateway.auth.token，OpenClaw HTTP API 认证用，任意字符串
GATEWAY_TOKEN=gw-secret-token

# Skill API 同步认证 token
SKILL_API_TOKEN=gw-secret-token

# ── OpenClaw ─────────────────────────────────────────
# OpenClaw state directory — must use absolute path (~/$HOME not expanded in .env)
# macOS example: /Users/<you>/.openclaw
# Linux example: /home/<you>/.openclaw
OPENCLAW_STATE_DIR=/Users/you/.openclaw

# 默认模型 ID（需与 LiteLLM 中已配置的模型名一致）
DEFAULT_MODEL_ID=anthropic/claude-sonnet-4

# ── LiteLLM Model Provider (optional — enables AI responses) ──
LITELLM_BASE_URL=
LITELLM_API_KEY=

# ── OpenRouter (optional — enables memory search embedding) ──
OPENROUTER_API_KEY=

# ── Email (Resend) ───────────────────────────────────
RESEND_API_KEY=
EMAIL_SENDER=Nexu <noreply@nexu.io>

# ── Feishu Feedback (optional — sends user feedback to Feishu group) ──
FEISHU_FEEDBACK_WEBHOOK_URL=
FEISHU_FEEDBACK_CHAT_ID=

# ── Analytics (optional — Amplitude frontend tracking) ──
VITE_AMPLITUDE_API_KEY=

# ── Server ───────────────────────────────────────────
PORT=3000
WEB_URL=http://localhost:5173
