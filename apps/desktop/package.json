{
  "name": "@nexu/desktop",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "main": "dist-electron/main/bootstrap.js",
  "description": "Electron desktop shell for Nexu local runtime",
  "packageManager": "pnpm@10.31.0",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "start:electron": "node -e \"console.error('Use pnpm desktop:start from the nexu project root.'); process.exit(1)\"",
    "prepare:api-sidecar": "node ./scripts/prepare-api-sidecar.mjs",
    "prepare:gateway-sidecar": "node ./scripts/prepare-gateway-sidecar.mjs",
    "prepare:openclaw-sidecar": "node ./scripts/prepare-openclaw-sidecar.mjs",
    "prepare:pglite-sidecar": "node ./scripts/prepare-pglite-sidecar.mjs",
    "prepare:runtime-sidecars": "node ./scripts/prepare-runtime-sidecars.mjs",
    "prepare:web-sidecar": "node ./scripts/prepare-web-sidecar.mjs",
    "package:sidecars": "node ./scripts/prepare-runtime-sidecars.mjs --release",
    "dist:mac": "node ./scripts/dist-mac.mjs",
    "dist:mac:unsigned": "node ./scripts/dist-mac.mjs --unsigned",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@amplitude/unified": "1.0.0-beta.38",
    "@electric-sql/pglite": "^0.3.16",
    "@electric-sql/pglite-socket": "^0.0.22",
    "@hey-api/client-fetch": "^0.8.4",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.3",
    "@sentry/electron": "^7.10.0",
    "@tanstack/react-query": "^5.66.9",
    "better-auth": "^1.4.19",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-updater": "^6.3.9",
    "lucide-react": "^0.474.0",
    "pg": "^8.13.1",
    "pino": "^10.3.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.6.0",
    "sonner": "^2.0.1",
    "tailwind-merge": "^3.0.1"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.13.4",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.0.4",
    "electron": "^37.2.5",
    "electron-builder": "^26.0.12",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.5",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "build": {
    "appId": "io.nexu.desktop",
    "productName": "Nexu",
    "icon": "build/icon.icns",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json",
      "!node_modules/openclaw",
      "!node_modules/openclaw/**/*"
    ],
    "extraResources": [
      {
        "from": ".dist-runtime",
        "to": "runtime"
      },
      {
        "from": "build-config.json",
        "to": "build-config.json",
        "filter": ["**/*"]
      }
    ],
    "afterSign": "./scripts/notarize.cjs",
    "copyright": "Copyright © 2026 Powerformer, Inc.",
    "mac": {
      "icon": "build/icon.icns",
      "category": "public.app-category.developer-tools",
      "target": ["dmg", "zip"],
      "artifactName": "${productName}-${arch}.${ext}",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "extendInfo": {
        "LSUIElement": true
      }
    },
    "dmg": {
      "size": "2g"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "nexu-io",
        "repo": "nexu"
      }
    ]
  }
}
